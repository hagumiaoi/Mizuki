---
import { getCollection } from "astro:content";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { buildNovelCategories } from "@utils/novel-structure";

const allNovelEntries = await getCollection("novels");
const categories = buildNovelCategories(allNovelEntries);
---

<MainGridLayout title="小说">
	<div class="prose dark:prose-invert max-w-none">
		<h1>小说</h1>
		<p>欢迎来到小说栏目，请先选择分类。</p>

		<div class="flex flex-col gap-4 mt-8">
			{
				categories.map((category) => {
					const categoryLink = `/novels/${category.categorySlug}/`;
					const categoryCover = category.works.find((work) => {
						return Boolean(work.coverEntry.data.cover);
					})?.coverEntry.data.cover;
					const workTitles = category.works
						.slice(0, 3)
						.map((work) => work.coverEntry.data.title)
						.filter(Boolean);

					return (
						<a
							href={categoryLink}
							class="block p-4 md:p-5 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-400 transition-colors"
						>
							<div class="flex flex-col md:flex-row gap-4 md:gap-5">
								{categoryCover && (
									<img
										src={categoryCover}
										alt={category.categoryTitle}
										class="w-full md:w-52 h-40 md:h-36 object-cover rounded-md shrink-0"
									/>
								)}
								<div class="min-w-0 flex-1">
									<h2 class="text-xl font-bold mb-2">{category.categoryTitle}</h2>
									<p class="text-sm text-gray-600 dark:text-gray-400 mb-2">
										作品数: {category.works.length}
									</p>
									{workTitles.length > 0 && (
										<p class="text-gray-700 dark:text-gray-300 line-clamp-2">
											包含：{workTitles.join("、")}
										</p>
									)}
								</div>
							</div>
						</a>
					);
				})
			}
		</div>

		{categories.length === 0 && (
			<div class="text-center py-12">
				<p class="text-gray-600 dark:text-gray-400">暂无小说</p>
			</div>
		)}
	</div>
</MainGridLayout>
