---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import MainGridLayout from "@layouts/MainGridLayout.astro";

function normalizeEntryId(id: string) {
	return id.replace(/^\/+|\/+$/g, "");
}

function getIdParts(id: string) {
	return normalizeEntryId(id).split("/").filter(Boolean);
}

function isNovelCoverEntry(entry: CollectionEntry<"novels">) {
	const parts = getIdParts(entry.id);
	return parts.length === 1 || (parts.length === 2 && parts[0] === parts[1]);
}

function isNovelChapterEntry(entry: CollectionEntry<"novels">) {
	const parts = getIdParts(entry.id);
	return parts.length >= 2 && !isNovelCoverEntry(entry);
}

// 生成静态路径
export async function getStaticPaths() {
	const allNovelEntries = await getCollection("novels");

	const paths = allNovelEntries
		.filter((entry) => {
			const parts = entry.id.replace(/^\/+|\/+$/g, "").split("/").filter(Boolean);
			const isCover = parts.length === 1 || (parts.length === 2 && parts[0] === parts[1]);
			return parts.length >= 2 && !isCover;
		})
		.map((entry) => {
			const parts = entry.id.replace(/^\/+|\/+$/g, "").split("/").filter(Boolean);
			const novelSlug = parts[0];
			const chapterFile = parts[parts.length - 1]
				.replace(/\.md$/, "")
				.replace(/^\d+-/, "");

			return {
				params: {
					novelSlug,
					chapterSlug: chapterFile,
				},
				props: { entry, novelSlug },
			};
		});

	return paths;
}

interface Props {
	entry: CollectionEntry<"novels">;
	novelSlug: string;
}

const { entry, novelSlug } = Astro.props as Props;
const { Content } = await render(entry);

// 获取所有小说
const allNovelEntries = await getCollection("novels");

// 获取这个小说的所有章节
const allChapters = allNovelEntries
	.filter((e) => {
		const parts = getIdParts(e.id);
		return parts[0] === novelSlug && isNovelChapterEntry(e);
	})
	.sort((a, b) => {
		const numA = a.data.chapterNumber || 999;
		const numB = b.data.chapterNumber || 999;
		return numA - numB;
	});

// 找到当前章节的索引
const currentIndex = allChapters.findIndex(
	(e) => e.id === entry.id
);

const prevChapter =
	currentIndex > 0 ? allChapters[currentIndex - 1] : null;
const nextChapter =
	currentIndex < allChapters.length - 1
		? allChapters[currentIndex + 1]
		: null;

const novelInfo = allNovelEntries.find((e) => {
	const parts = getIdParts(e.id);
	return parts[0] === novelSlug && isNovelCoverEntry(e);
});

function getChapterUrl(chapterEntry: CollectionEntry<"novels">) {
	const parts = getIdParts(chapterEntry.id);
	const fileName = parts[parts.length - 1]
		.replace(/\.md$/, "")
		.replace(/^\d+-/, "");
	return `/novels/${novelSlug}/${fileName}/`;
}
---

<MainGridLayout title={entry.data.title}>
	<div class="prose dark:prose-invert max-w-none">
		<div class="mb-8 pb-8 border-b border-gray-200 dark:border-gray-700">
			<div class="mb-4">
				<a href={`/novels/${novelSlug}/`} class="text-blue-600 dark:text-blue-400 hover:underline">
					← 返回 {novelInfo?.data.title}
				</a>
			</div>

			<h1>{entry.data.title}</h1>

			{entry.data.published && (
				<p class="text-sm text-gray-500 dark:text-gray-400">
					发布于 {new Date(entry.data.published).toLocaleDateString("zh-CN")}
				</p>
			)}
		</div>

		<div class="my-8">
			<Content />
		</div>

		<div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
			<div class="flex justify-between items-center">
				{prevChapter ? (
					<a
						href={getChapterUrl(prevChapter)}
						class="text-blue-600 dark:text-blue-400 hover:underline"
					>
						← 上一章: {prevChapter.data.title}
					</a>
				) : (
					<div></div>
				)}

				<a
					href={`/novels/${novelSlug}/`}
					class="text-blue-600 dark:text-blue-400 hover:underline"
				>
					章节列表
				</a>

				{nextChapter ? (
					<a
						href={getChapterUrl(nextChapter)}
						class="text-blue-600 dark:text-blue-400 hover:underline"
					>
						下一章: {nextChapter.data.title} →
					</a>
				) : (
					<div></div>
				)}
			</div>
		</div>
	</div>
</MainGridLayout>
