---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import {
	buildNovelCategories,
	getChapterPath,
	getChapterSlugFromEntryId,
	getWorkPath,
	isLegacySingleWorkCategory,
	type NovelWork,
} from "../../utils/novel-structure";

export async function getStaticPaths() {
	const allNovelEntries = await getCollection("novels");
	const categories = buildNovelCategories(allNovelEntries);
	const routeSet = new Set<string>();
	const toRouteSlug = (segments: string[]) => segments.join("/");

	for (const category of categories) {
		if (isLegacySingleWorkCategory(category)) {
			const legacyWork = category.works[0];
			routeSet.add(toRouteSlug([category.categorySlug]));
			for (const chapter of legacyWork.chapterEntries) {
				routeSet.add(
					toRouteSlug([
						category.categorySlug,
						getChapterSlugFromEntryId(chapter.id),
					]),
				);
			}
			continue;
		}

		routeSet.add(toRouteSlug([category.categorySlug]));
		for (const work of category.works) {
			routeSet.add(toRouteSlug([category.categorySlug, work.workSlug]));
			for (const chapter of work.chapterEntries) {
				routeSet.add(
					toRouteSlug([
						category.categorySlug,
						work.workSlug,
						getChapterSlugFromEntryId(chapter.id),
					]),
				);
			}
		}
	}

	return Array.from(routeSet).map((slug) => ({
		params: { slug },
	}));
}

const slugParts = (Astro.params.slug || "").split("/").filter(Boolean);
const allNovelEntries = await getCollection("novels");
const categories = buildNovelCategories(allNovelEntries);
const category = categories.find((item) => item.categorySlug === slugParts[0]);

if (!category) {
	throw new Error(`小说分类不存在: ${slugParts[0] || ""}`);
}

type PageType = "category" | "work" | "chapter";

let pageType: PageType = "category";
let currentWork: NovelWork | null = null;
let currentChapter: CollectionEntry<"novels"> | null = null;

if (slugParts.length === 1) {
	if (isLegacySingleWorkCategory(category)) {
		pageType = "work";
		currentWork = category.works[0];
	}
} else if (slugParts.length === 2) {
	if (isLegacySingleWorkCategory(category)) {
		const legacyWork = category.works[0];
		const matchedChapter = legacyWork.chapterEntries.find((chapter) => {
			return getChapterSlugFromEntryId(chapter.id) === slugParts[1];
		});

		if (!matchedChapter) {
			throw new Error(`小说章节不存在: ${slugParts.join("/")}`);
		}

		pageType = "chapter";
		currentWork = legacyWork;
		currentChapter = matchedChapter;
	} else {
		const matchedWork = category.works.find((work) => {
			return work.workSlug === slugParts[1];
		});

		if (!matchedWork) {
			throw new Error(`小说作品不存在: ${slugParts.join("/")}`);
		}

		pageType = "work";
		currentWork = matchedWork;
	}
} else if (slugParts.length === 3) {
	const matchedWork = category.works.find((work) => {
		return work.workSlug === slugParts[1];
	});

	if (!matchedWork) {
		throw new Error(`小说作品不存在: ${slugParts.join("/")}`);
	}

	const matchedChapter = matchedWork.chapterEntries.find((chapter) => {
		return getChapterSlugFromEntryId(chapter.id) === slugParts[2];
	});

	if (!matchedChapter) {
		throw new Error(`小说章节不存在: ${slugParts.join("/")}`);
	}

	pageType = "chapter";
	currentWork = matchedWork;
	currentChapter = matchedChapter;
} else {
	throw new Error(`无效小说路径: ${slugParts.join("/")}`);
}

let WorkContent: null | Awaited<ReturnType<typeof render>>["Content"] = null;
if (pageType === "work" && currentWork) {
	const rendered = await render(currentWork.coverEntry);
	WorkContent = rendered.Content;
}

let ChapterContent: null | Awaited<ReturnType<typeof render>>["Content"] = null;
if (pageType === "chapter" && currentChapter) {
	const rendered = await render(currentChapter);
	ChapterContent = rendered.Content;
}

const chapterList = currentWork?.chapterEntries || [];
const currentChapterIndex = currentChapter
	? chapterList.findIndex((chapter) => chapter.id === currentChapter.id)
	: -1;
const prevChapter = currentChapterIndex > 0 ? chapterList[currentChapterIndex - 1] : null;
const nextChapter =
	currentChapterIndex >= 0 && currentChapterIndex < chapterList.length - 1
		? chapterList[currentChapterIndex + 1]
		: null;

const pageTitle =
	pageType === "category"
		? category.categoryTitle
		: pageType === "work" && currentWork
			? currentWork.coverEntry.data.title
			: currentChapter?.data.title || "小说";
---

{pageType === "category" && (
	<MainGridLayout title={pageTitle}>
		<div class="prose dark:prose-invert max-w-none">
			<h1>{category.categoryTitle}</h1>
			<p>请选择想阅读的作品。</p>

			<div class="flex flex-col gap-4 mt-8">
				{category.works.map((work) => (
					<a
						href={getWorkPath(work)}
						class="block p-4 md:p-5 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-400 transition-colors"
					>
						<div class="flex flex-col md:flex-row gap-4 md:gap-5">
							{work.coverEntry.data.cover && (
								<img
									src={work.coverEntry.data.cover}
									alt={work.coverEntry.data.title}
									class="w-full md:w-52 h-40 md:h-36 object-cover rounded-md shrink-0"
								/>
							)}
							<div class="min-w-0 flex-1">
								<h2 class="text-xl font-bold mb-2">{work.coverEntry.data.title}</h2>
								{work.coverEntry.data.author && (
									<p class="text-sm text-gray-600 dark:text-gray-400 mb-2">
										作者: {work.coverEntry.data.author}
									</p>
								)}
								{work.coverEntry.data.status && (
									<p class="text-sm font-semibold text-blue-600 dark:text-blue-400 mb-2">
										{work.coverEntry.data.status}
									</p>
								)}
								<p class="text-gray-700 dark:text-gray-300 line-clamp-2">
									{work.coverEntry.data.description}
								</p>
								{work.coverEntry.data.tags && work.coverEntry.data.tags.length > 0 && (
									<div class="mt-3 flex flex-wrap gap-2">
										{work.coverEntry.data.tags.map((tag) => (
											<span class="text-xs px-2 py-1 rounded bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">
												{tag}
											</span>
										))}
									</div>
								)}
							</div>
						</div>
					</a>
				))}
			</div>

			{category.works.length === 0 && (
				<div class="text-center py-12">
					<p class="text-gray-600 dark:text-gray-400">暂无作品</p>
				</div>
			)}
		</div>
	</MainGridLayout>
)}

{pageType === "work" && currentWork && (
	<MainGridLayout
		title={pageTitle}
		contentBackdrop={currentWork.coverEntry.data.cover || ""}
	>
		<div class="prose dark:prose-invert max-w-none reading-content novel-reading-theme">
			<div class="mb-8 novel-meta-panel">
				{!currentWork.isLegacy && (
					<div class="mb-4">
						<a
							href={`/novels/${category.categorySlug}/`}
							class="reading-nav-link"
						>
							← 返回 {category.categoryTitle}
						</a>
					</div>
				)}

				<h1 class="novel-night-title">{currentWork.coverEntry.data.title}</h1>

				<div class="flex flex-wrap gap-4 my-4 text-sm">
					{currentWork.coverEntry.data.author && (
						<p>
							<strong>作者:</strong> {currentWork.coverEntry.data.author}
						</p>
					)}
					{currentWork.coverEntry.data.status && (
						<p>
							<strong>状态:</strong>
							<span class="font-semibold text-blue-600 dark:text-blue-400">
								{currentWork.coverEntry.data.status}
							</span>
						</p>
					)}
				</div>

				{currentWork.coverEntry.data.tags && currentWork.coverEntry.data.tags.length > 0 && (
					<div class="flex flex-wrap gap-2 mb-4">
						{currentWork.coverEntry.data.tags.map((tag) => (
							<span class="px-3 py-1 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-sm">
								{tag}
							</span>
						))}
					</div>
				)}
			</div>

			<div class="my-8 custom-md">
				{WorkContent && <WorkContent />}
			</div>

			<hr class="my-8" />

			<h2>章节列表</h2>
			<div class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-2">
				{currentWork.chapterEntries.length > 0 ? (
					currentWork.chapterEntries.map((chapter, index) => (
						<a
							href={getChapterPath(currentWork, chapter)}
							class="reading-chapter-card group flex items-start gap-3 rounded-[var(--radius-large)] border bg-[var(--card-bg)] px-4 py-3 transition-colors duration-150"
						>
							<span class="reading-chapter-badge inline-flex h-7 min-w-7 items-center justify-center rounded-full px-2 text-xs font-semibold">
								{chapter.data.chapterNumber || index + 1}
							</span>
							<div class="min-w-0 flex-1">
								<h3 class="reading-chapter-title !m-0 text-base font-semibold transition-colors">
									{chapter.data.title}
								</h3>
								{chapter.data.published && (
									<p class="!mb-0 !mt-1 text-xs text-[var(--content-meta)]">
										{new Date(chapter.data.published).toLocaleDateString("zh-CN")}
									</p>
								)}
							</div>
							<span class="reading-chapter-arrow text-sm text-[var(--content-meta)] transition-colors">→</span>
						</a>
					))
				) : (
					<p class="text-[var(--content-meta)]">暂无章节</p>
				)}
			</div>
		</div>
	</MainGridLayout>
)}

{pageType === "chapter" && currentWork && currentChapter && (
	<MainGridLayout title={pageTitle}>
		<div class="prose dark:prose-invert max-w-none reading-content novel-reading-theme">
			<div class="mb-8 pb-8 border-b border-gray-200 dark:border-gray-700 novel-meta-panel">
				<div class="mb-4">
					<a href={getWorkPath(currentWork)} class="reading-nav-link">
						← 返回 {currentWork.coverEntry.data.title}
					</a>
				</div>

				<h1 class="novel-night-title">{currentChapter.data.title}</h1>

				{currentChapter.data.published && (
					<p class="text-sm text-gray-500 dark:text-gray-400">
						发布于 {new Date(currentChapter.data.published).toLocaleDateString("zh-CN")}
					</p>
				)}
			</div>

			<div class="my-8 custom-md">
				{ChapterContent && <ChapterContent />}
			</div>

			<div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
				<div class="flex justify-between items-center">
					{prevChapter ? (
						<a
							href={getChapterPath(currentWork, prevChapter)}
							class="reading-nav-link"
						>
							← 上一章: {prevChapter.data.title}
						</a>
					) : (
						<div></div>
					)}

					<a
						href={getWorkPath(currentWork)}
						class="reading-nav-link"
					>
						章节列表
					</a>

					{nextChapter ? (
						<a
							href={getChapterPath(currentWork, nextChapter)}
							class="reading-nav-link"
						>
							下一章: {nextChapter.data.title} →
						</a>
					) : (
						<div></div>
					)}
				</div>
			</div>
		</div>
	</MainGridLayout>
)}

<style is:global>
	.reading-content .novel-meta-panel {
		position: relative;
		padding: 1.15rem 1.2rem 1rem;
		border-radius: var(--radius-large);
		border: 1px solid color-mix(in oklch, var(--primary) 26%, var(--line-color) 74%);
		background:
			radial-gradient(circle at 84% 18%, color-mix(in oklch, var(--primary) 16%, transparent 84%) 0%, transparent 42%),
			radial-gradient(circle at 14% 72%, color-mix(in oklch, var(--primary) 11%, transparent 89%) 0%, transparent 36%),
			linear-gradient(135deg, color-mix(in oklch, var(--card-bg) 89%, var(--primary) 11%) 0%, color-mix(in oklch, var(--card-bg) 95%, var(--page-bg) 5%) 100%);
		backdrop-filter: blur(8px);
	}

	.reading-content .novel-meta-panel :is(p, strong, a) {
		color: color-mix(in oklch, var(--btn-content) 74%, var(--content-meta) 26%);
	}

	.reading-content .novel-meta-panel::before,
	.reading-content .novel-meta-panel::after {
		content: "✦";
		position: absolute;
		line-height: 1;
		color: color-mix(in oklch, var(--primary) 68%, var(--card-bg) 32%);
		text-shadow: 0 0 0.55rem color-mix(in oklch, var(--primary) 45%, transparent 55%);
		opacity: 0.92;
		pointer-events: none;
	}

	.reading-content .novel-meta-panel::before {
		top: 0.55rem;
		right: 0.85rem;
		font-size: 0.82rem;
	}

	.reading-content .novel-meta-panel::after {
		top: 1.2rem;
		right: 1.7rem;
		font-size: 0.55rem;
		opacity: 0.72;
	}

	:root:not(.dark) .reading-content .novel-meta-panel {
		background:
			radial-gradient(circle at 84% 18%, color-mix(in oklch, var(--primary) 10%, transparent 90%) 0%, transparent 42%),
			radial-gradient(circle at 14% 72%, color-mix(in oklch, var(--primary) 8%, transparent 92%) 0%, transparent 36%),
			linear-gradient(135deg, color-mix(in oklch, var(--card-bg) 96%, var(--primary) 4%) 0%, color-mix(in oklch, var(--card-bg) 97%, var(--page-bg) 3%) 100%);
	}

	.reading-content .novel-night-title {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: color-mix(in oklch, var(--btn-content) 78%, var(--card-bg) 22%);
		letter-spacing: 0.02em;
		text-shadow:
			0 0 0.45rem color-mix(in oklch, var(--primary) 42%, transparent 58%),
			0 0 1.1rem color-mix(in oklch, var(--primary) 22%, transparent 78%);
	}

	:root:not(.dark) .reading-content .novel-night-title {
		color: color-mix(in oklch, var(--deep-text) 82%, var(--btn-content) 18%);
		text-shadow: 0 0 0.35rem color-mix(in oklch, var(--primary) 25%, transparent 75%);
	}

	.reading-content .novel-night-title::before,
	.reading-content .novel-night-title::after {
		content: "✦";
		font-size: 0.62em;
		line-height: 1;
		opacity: 0.95;
		color: color-mix(in oklch, var(--primary) 75%, var(--card-bg) 25%);
		text-shadow: 0 0 0.6rem color-mix(in oklch, var(--primary) 45%, transparent 55%);
	}

	.reading-content .novel-night-title::before {
		transform: translateY(-0.36em) scale(0.92);
	}

	.reading-content .novel-night-title::after {
		transform: translateY(0.22em) scale(0.78);
	}
</style>
