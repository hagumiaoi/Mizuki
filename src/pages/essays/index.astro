---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import MainGridLayout from "@layouts/MainGridLayout.astro";

// 获取所有随笔（只获取 index.md 文件作为条目）
const allEntries = await getCollection("essays");
const essays = allEntries.filter((entry) => {
	const filePathParts = entry.id.split("/");
	return filePathParts[filePathParts.length - 1] === "index.md";
});

essays.sort((a, b) => {
	const dateA = new Date(a.data.published || 0).getTime();
	const dateB = new Date(b.data.published || 0).getTime();
	return dateB - dateA;
});

---

<MainGridLayout title="随笔">
	<div class="prose dark:prose-invert max-w-none">
		<h1>随笔</h1>
		<p>这里是随笔列表。</p>

		<div class="space-y-4 mt-6">
			{essays.map((e) => {
				const slug = e.id.split("/")[0];
				return (
					<a href={`/essays/${slug}/`} class="block p-4 rounded border hover:border-blue-500">
						<h2 class="text-lg font-semibold">{e.data.title}</h2>
						{e.data.description && <p class="text-sm text-gray-600">{e.data.description}</p>}
					</a>
				);
			})}
		</div>

		{essays.length === 0 && <p class="text-gray-500">暂无随笔</p>}
	</div>
</MainGridLayout>
