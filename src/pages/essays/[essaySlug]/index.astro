---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import Markdown from "@components/misc/Markdown.astro";

export async function getStaticPaths() {
	const all = await getCollection("essays");
	const paths = all
		.filter((entry) => entry.id.endsWith("index.md"))
		.map((entry) => ({ params: { essaySlug: entry.id.split("/")[0] }, props: { entry } }));
	return paths;
}

interface Props {
	entry: CollectionEntry<"essays">;
}

const { entry } = Astro.props as Props;
const { Content } = await render(entry);

---

<MainGridLayout title={entry.data.title}>
	<div class="prose dark:prose-invert max-w-none">
		<h1>{entry.data.title}</h1>
		{entry.data.author && <p class="text-sm text-gray-600">作者: {entry.data.author}</p>}
		<div class="my-6 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg">
			<Markdown class="markdown-content">
				<Content />
			</Markdown>
		</div>
	</div>
</MainGridLayout>
