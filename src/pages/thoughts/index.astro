---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import MainGridLayout from "@layouts/MainGridLayout.astro";

type ThoughtDisplayData = CollectionEntry<"thoughts">["data"] & {
	cover?: string;
	status?: string;
	tags?: string[];
	author?: string;
};

function normalizeEntryId(id: string) {
	return id.replace(/^\/+|\/+$/g, "");
}

function getIdParts(id: string) {
	return normalizeEntryId(id).split("/").filter(Boolean);
}

function isThoughtCoverEntry(entry: CollectionEntry<"thoughts">) {
	const parts = getIdParts(entry.id);
	return parts.length === 1 || (parts.length === 2 && parts[0] === parts[1]);
}

const allThoughtEntries = await getCollection("thoughts");
const thoughts = allThoughtEntries.filter((entry) => isThoughtCoverEntry(entry));

thoughts.sort((a, b) => {
	const dateA = new Date(a.data.published || 0).getTime();
	const dateB = new Date(b.data.published || 0).getTime();
	return dateB - dateA;
});
---

<MainGridLayout title="简思">
	<div class="prose dark:prose-invert max-w-none sakura-select sakura-select--thought">
		<div class="sakura-select-hero not-prose mb-7">
			<h1 class="sakura-select-title">简思</h1>
			<p class="sakura-select-subtitle">欢迎来到简思栏目。</p>
		</div>

		<div class="flex flex-col gap-4 mt-8">
			{thoughts.map((thought) => {
				const thoughtData = thought.data as ThoughtDisplayData;
				const thoughtDir = getIdParts(thought.id)[0];
				const thoughtTitle = thoughtData.title;
				const thoughtLink = `/thoughts/${thoughtDir}/`;

				return (
					<a
						href={thoughtLink}
						class="sakura-select-card block p-4 md:p-5 rounded-lg border transition-colors"
					>
						<div class="flex flex-col md:flex-row gap-4 md:gap-5">
							{thoughtData.cover && (
								<img
									src={thoughtData.cover}
									alt={thoughtTitle}
									class="w-full md:w-52 h-40 md:h-36 object-cover rounded-md shrink-0"
								/>
							)}
							<div class="min-w-0 flex-1">
								<h2 class="sakura-select-card-title text-xl font-bold mb-2">{thoughtTitle}</h2>
								{thoughtData.author && (
									<p class="sakura-select-meta text-sm mb-2">
										作者: {thoughtData.author}
									</p>
								)}
								{thoughtData.status && (
									<p class="sakura-select-status text-sm font-semibold mb-2">
										{thoughtData.status}
									</p>
								)}
								<p class="sakura-select-desc line-clamp-2">
									{thoughtData.description}
								</p>
								{thoughtData.tags && thoughtData.tags.length > 0 && (
									<div class="mt-3 flex flex-wrap gap-2">
										{thoughtData.tags.map((tag) => (
											<span class="sakura-select-tag text-xs px-2 py-1 rounded">
												{tag}
											</span>
										))}
									</div>
								)}
							</div>
						</div>
					</a>
				);
			})}
		</div>

		{thoughts.length === 0 && (
			<div class="text-center py-12">
				<p class="text-gray-600 dark:text-gray-400">暂无简思</p>
			</div>
		)}
	</div>
</MainGridLayout>
