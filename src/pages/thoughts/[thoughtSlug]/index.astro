---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import MainGridLayout from "@layouts/MainGridLayout.astro";

type ThoughtDisplayData = CollectionEntry<"thoughts">["data"] & {
	cover?: string;
	author?: string;
	status?: string;
	tags?: string[];
	chapterNumber?: number;
};

function normalizeEntryId(id: string) {
	return id.replace(/^\/+|\/+$/g, "");
}

function getIdParts(id: string) {
	return normalizeEntryId(id).split("/").filter(Boolean);
}

function isThoughtCoverEntry(entry: CollectionEntry<"thoughts">) {
	const parts = getIdParts(entry.id);
	return parts.length === 1 || (parts.length === 2 && parts[0] === parts[1]);
}

function isThoughtChapterEntry(entry: CollectionEntry<"thoughts">) {
	const parts = getIdParts(entry.id);
	return parts.length >= 2 && !isThoughtCoverEntry(entry);
}

export async function getStaticPaths() {
	const allThoughtEntries = await getCollection("thoughts");

	const paths = allThoughtEntries
		.filter((entry) => {
			const parts = entry.id.replace(/^\/+|\/+$/g, "").split("/").filter(Boolean);
			return parts.length === 1 || (parts.length === 2 && parts[0] === parts[1]);
		})
		.map((entry) => ({
			params: {
				thoughtSlug: entry.id.replace(/^\/+|\/+$/g, "").split("/").filter(Boolean)[0],
			},
			props: { entry },
		}));

	return paths;
}

interface Props {
	entry: CollectionEntry<"thoughts">;
}

const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const thoughtDir = getIdParts(entry.id)[0];

const allThoughtEntries = await getCollection("thoughts");

const chapterFiles = allThoughtEntries.filter((entryItem) => {
	const parts = getIdParts(entryItem.id);
	return parts[0] === thoughtDir && isThoughtChapterEntry(entryItem);
});

chapterFiles.sort((a, b) => {
	const numA = (a.data as ThoughtDisplayData).chapterNumber || 999;
	const numB = (b.data as ThoughtDisplayData).chapterNumber || 999;
	return numA - numB;
});

const entryData = entry.data as ThoughtDisplayData;
const thoughtTitle = entryData.title;

---

<MainGridLayout title={thoughtTitle}>
	<div class="prose dark:prose-invert max-w-none reading-content">
		<div class="mb-8">
			<h1>{thoughtTitle}</h1>

			<div class="flex flex-wrap gap-4 my-4 text-sm">
				{
					entryData.author && (
						<p>
							<strong>作者:</strong> {entryData.author}
						</p>
					)
				}
				{
					entryData.status && (
						<p>
							<strong>状态:</strong>
							<span class="font-semibold text-blue-600 dark:text-blue-400">
								{entryData.status}
							</span>
						</p>
					)
				}
			</div>

			{
				entryData.tags && entryData.tags.length > 0 && (
					<div class="flex flex-wrap gap-2 mb-4">
						{entryData.tags.map((tag) => (
							<span class="px-3 py-1 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-sm">
								{tag}
							</span>
						))}
					</div>
				)
			}
		</div>

		<div class="my-8 custom-md">
			<Content />
		</div>

		<hr class="my-8" />

		<h2>章节列表</h2>

		<div class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-2">
			{
				chapterFiles.length > 0 ? (
					chapterFiles.map((chapter, index) => {
						const chapterData = chapter.data as ThoughtDisplayData;
						const chapterParts = getIdParts(chapter.id);
						const chapterFileName = chapterParts[chapterParts.length - 1]
							.replace(/\.md$/, "")
							.replace(/^\d+-/, "");

						return (
							<a
								href={`/thoughts/${thoughtDir}/${chapterFileName}/`}
								class="group flex items-start gap-3 rounded-[var(--radius-large)] border border-[var(--line-color)] bg-[var(--card-bg)] px-4 py-3 transition-colors duration-150 hover:border-[var(--primary)] hover:bg-[var(--btn-card-bg-hover)]"
							>
								<span class="inline-flex h-7 min-w-7 items-center justify-center rounded-full bg-[var(--btn-regular-bg)] px-2 text-xs font-semibold text-[var(--btn-content)]">
									{chapterData.chapterNumber || index + 1}
								</span>
								<div class="min-w-0 flex-1">
									<h3 class="!m-0 text-base font-semibold text-black/80 transition-colors group-hover:text-[var(--primary)] dark:text-white/85">
										{chapter.data.title}
									</h3>
									{chapter.data.published && (
										<p class="!mb-0 !mt-1 text-xs text-[var(--content-meta)]">
											{new Date(chapter.data.published).toLocaleDateString("zh-CN")}
										</p>
									)}
								</div>
								<span class="text-sm text-[var(--content-meta)] transition-colors group-hover:text-[var(--primary)]">→</span>
							</a>
						);
					})
				) : (
					<p class="text-[var(--content-meta)]">暂无章节</p>
				)
			}
		</div>
	</div>
</MainGridLayout>
