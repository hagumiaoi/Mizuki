---
import fs from "node:fs";
import path from "node:path";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const galleryDir = path.join(process.cwd(), "public", "images", "home-gallery");
const supportedImageExt = new Set([".jpg", ".jpeg", ".png", ".webp", ".avif", ".gif"]);

const galleryImages = fs.existsSync(galleryDir)
	? fs
			.readdirSync(galleryDir)
			.filter((fileName) =>
				supportedImageExt.has(path.extname(fileName).toLowerCase()),
			)
			.sort((a, b) => a.localeCompare(b, "zh-CN", { numeric: true }))
			.map((fileName) => `/images/home-gallery/${encodeURIComponent(fileName)}`)
	: [];
---

<MainGridLayout title="主页">
	<section class="sakura-select sakura-select--thought">
		<div class="sakura-select-hero">
			<h1 class="sakura-select-title text-2xl md:text-3xl font-bold">主页</h1>
			<p class="sakura-select-subtitle text-sm md:text-base">
				这里是主页nya！可以浏览moi跑的图片！
			</p>
		</div>
	</section>

	{
		galleryImages.length > 0 ? (
			<section class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
				{galleryImages.map((src, index) => (
					<article class="overflow-hidden rounded-[var(--radius-large)] bg-[var(--card-bg)]">
						<a
							href={src}
							data-image-preview="home-gallery"
							data-caption={`首页图片 ${index + 1}`}
							aria-label={`放大查看首页图片 ${index + 1}`}
							class="group block"
						>
							<img
								src={src}
								alt={`首页图片 ${index + 1}`}
								loading="lazy"
								class="h-56 w-full object-cover transition-transform duration-200 group-hover:scale-[1.02]"
							/>
						</a>
					</article>
				))}
			</section>
		) : (
			<section class="mt-4 rounded-[var(--radius-large)] bg-[var(--card-bg)] p-6 text-[var(--meta-color)]">
				当前还没有图片，请先上传到 <strong>/public/images/home-gallery</strong>。
			</section>
		)
	}
</MainGridLayout>

<style is:global>
	.is-home #sidebar,
	.is-home .right-sidebar-container {
		display: none !important;
	}

	.is-home #main-grid {
		grid-template-columns: minmax(0, 1fr) !important;
	}

	.is-home #swup-container {
		grid-column: 1 / -1 !important;
	}
</style>
